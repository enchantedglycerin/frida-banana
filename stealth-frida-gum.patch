diff --git a/gum/backend-linux/gummemory-linux.c b/gum/backend-linux/gummemory-linux.c
index 80c70d7..1f813ca 100644
--- a/gum/backend-linux/gummemory-linux.c
+++ b/gum/backend-linux/gummemory-linux.c
@@ -21,6 +21,16 @@
 #include <sys/syscall.h>
 #include <sys/uio.h>
 
+#ifdef HAVE_ANDROID
+# include <sys/prctl.h>
+# ifndef PR_SET_VMA
+#  define PR_SET_VMA 0x53564d41
+# endif
+# ifndef PR_SET_VMA_ANON_NAME
+#  define PR_SET_VMA_ANON_NAME 0
+# endif
+#endif
+
 #if defined (HAVE_I386) && GLIB_SIZEOF_VOID_P == 4
 # define GUM_SYS_PROCESS_VM_READV   347
 # define GUM_SYS_PROCESS_VM_WRITEV  348
@@ -244,6 +254,22 @@ gum_try_mprotect (gpointer address,
 
   result = mprotect (aligned_address, aligned_size, posix_prot);
 
+#ifdef HAVE_ANDROID
+  /*
+   * Stealth: when gum commits its own code (allocated RW, then flipped to RX
+   * under the forced-W^X path), label the now-executable region as an ART JIT
+   * code cache so it does not appear as an unnamed anonymous executable
+   * mapping. Anon naming is a no-op on file-backed VMAs, so this never touches
+   * the target's own modules.
+   */
+  if (result == 0 && (posix_prot & PROT_EXEC) != 0)
+  {
+    prctl (PR_SET_VMA, PR_SET_VMA_ANON_NAME,
+        (unsigned long) aligned_address, (unsigned long) aligned_size,
+        (unsigned long) "dalvik-jit-code-cache");
+  }
+#endif
+
   return result == 0;
 }
 
diff --git a/gum/backend-posix/gummemory-posix.c b/gum/backend-posix/gummemory-posix.c
index 848b430..224f218 100644
--- a/gum/backend-posix/gummemory-posix.c
+++ b/gum/backend-posix/gummemory-posix.c
@@ -13,6 +13,16 @@
 #include <unistd.h>
 #include <sys/mman.h>
 
+#ifdef HAVE_ANDROID
+# include <sys/prctl.h>
+# ifndef PR_SET_VMA
+#  define PR_SET_VMA 0x53564d41
+# endif
+# ifndef PR_SET_VMA_ANON_NAME
+#  define PR_SET_VMA_ANON_NAME 0
+# endif
+#endif
+
 typedef struct _GumAllocNearContext GumAllocNearContext;
 typedef struct _GumEnumerateFreeRangesContext GumEnumerateFreeRangesContext;
 
@@ -264,6 +274,31 @@ gum_try_suggest_allocation_base (const GumMemoryRange * range,
   return TRUE;
 }
 
+#ifdef HAVE_ANDROID
+
+/*
+ * Stealth: give every anonymous region gum maps an ART-like name via
+ * PR_SET_VMA_ANON_NAME so it blends with the app's own [anon:dalvik-*]
+ * regions instead of standing out as an unnamed anonymous mapping. The name
+ * pointer must stay valid for the life of the mapping (older Android kernels
+ * store the userspace pointer and read it lazily when generating
+ * /proc/self/maps), so only string literals (permanent .rodata) are used.
+ */
+static void
+gum_android_label_pages (gpointer base,
+                         gsize size,
+                         gint posix_prot)
+{
+  const char * name = ((posix_prot & PROT_EXEC) != 0)
+      ? "dalvik-jit-code-cache"
+      : "dalvik-LinearAlloc";
+
+  prctl (PR_SET_VMA, PR_SET_VMA_ANON_NAME, (unsigned long) base,
+      (unsigned long) size, (unsigned long) name);
+}
+
+#endif
+
